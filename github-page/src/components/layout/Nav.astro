---
import { NAV_ITEMS } from "@/config/site";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<nav class="border-b border-border">
  <div class="mx-auto flex max-w-3xl items-center justify-between px-6 py-5">
    <a href={base + "/"} class="font-mono text-sm tracking-tight text-text hover:text-accent">
      anima · bci
    </a>
    <ul class="flex items-center gap-6 text-sm">
      {
        NAV_ITEMS.map((item) => (
          <li>
            <a href={item.href} class="text-text-muted transition-colors hover:text-accent">
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</nav>
