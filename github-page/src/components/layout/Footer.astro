---
import { SITE } from "@/config/site";
const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-border">
  <div class="mx-auto max-w-5xl px-6 py-10">
    <div class="flex flex-col gap-3 text-sm text-text-muted md:flex-row md:items-center md:justify-between">
      <div class="flex items-center gap-4">
        <span>© {year} {SITE.author}</span>
        <a href={`mailto:${SITE.email}`} class="hover:text-accent">{SITE.email}</a>
        <a href={SITE.repo} target="_blank" rel="noopener" class="hover:text-accent">GitHub</a>
      </div>
    </div>
  </div>
</footer>
