---
interface Hotspot {
  id: number;
  title: string;
  desc: string;
  x: number;
  y: number;
}

interface Props {
  image: string;
  alt: string;
  href?: string;
  hotspots: readonly Hotspot[];
}

const { image, alt, href, hotspots } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const imgSrc = `${base}/${image}`;

const Wrapper = href ? "a" : "div";
const wrapperProps = href
  ? { href, target: "_blank", rel: "noopener" }
  : {};
---

<div class="space-y-6">
  <Wrapper
    {...wrapperProps}
    class:list={[
      "relative block overflow-hidden rounded-md border border-border bg-bg-card",
      href && "transition-colors hover:border-accent-border",
    ]}
  >
    <img src={imgSrc} alt={alt} loading="lazy" class="block w-full" />
    {hotspots.map((h) => (
      <span
        class="absolute flex h-7 w-7 -translate-x-1/2 -translate-y-1/2 items-center justify-center rounded-full border border-accent bg-bg-card text-xs font-semibold text-accent shadow-sm"
        style={`left: ${h.x}%; top: ${h.y}%;`}
        aria-label={`Hotspot ${h.id}: ${h.title}`}
      >
        {h.id}
      </span>
    ))}
  </Wrapper>

  <ol class="grid gap-x-6 gap-y-3 text-sm md:grid-cols-2">
    {hotspots.map((h) => (
      <li class="flex gap-3">
        <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full border border-accent bg-accent-soft text-xs font-semibold text-accent">
          {h.id}
        </span>
        <div>
          <p class="font-medium text-text">{h.title}</p>
          <p class="mt-0.5 leading-relaxed text-text-muted">{h.desc}</p>
        </div>
      </li>
    ))}
  </ol>
</div>
