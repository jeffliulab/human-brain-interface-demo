---
import BaseLayout from "@/layouts/BaseLayout.astro";
import StoryboardFrame from "@/components/storyboard/StoryboardFrame.astro";
import AnnotatedScreenshot from "@/components/prototype/AnnotatedScreenshot.astro";
import {
  CONTRIBUTION,
  DEMO_STILLS,
  HERO,
  LIVE_DEMO,
  PROTOTYPE_HOTSPOTS,
  SITE,
  STORYBOARD,
  TECH_DETAILS,
} from "@/config/site";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<BaseLayout>
  <article class="mx-auto max-w-3xl px-6 py-16">

    <!-- Hero -->
    <header>
      <p class="font-mono text-xs tracking-wide text-text-tertiary">
        BCI × EMBODIED AI · 2026
      </p>
      <h1 class="mt-3 text-3xl font-semibold leading-tight tracking-tight md:text-[2.5rem] md:leading-[1.15]">
        {HERO.h1}
      </h1>
      <p class="mt-2 font-mono text-sm text-text-muted">{HERO.h1En}</p>

      <p class="mt-6 text-base leading-relaxed text-text">{HERO.subhead}</p>
    </header>

    <!-- Interactive Prototype (moved to top) -->
    <section id="prototype" class="mt-16 scroll-mt-8">
      <h2 class="text-sm font-medium uppercase tracking-wider text-text-tertiary">可交互原型 · Interactive Prototype</h2>
      <p class="mt-4 text-sm leading-relaxed text-text">
        完整的意图-行动链路部署在 Hetzner，可直接在浏览器中交互操作。界面左栏 BCI 监控、中栏 MuJoCo Live View、右栏 Anima 任务执行栈。下图为 2026-04-21 运行时截图，6 个关键区域标号对应说明——点击截图即可打开在线 Demo。
      </p>

      <div class="mt-6">
        <AnnotatedScreenshot
          image="prototype/panorama.png"
          alt="Anima × BCI dashboard — Stretch RE3 autonomously executing DRINK_WATER"
          href={LIVE_DEMO.url}
          hotspots={PROTOTYPE_HOTSPOTS}
        />
      </div>

      <div class="mt-6 flex flex-wrap items-center gap-x-4 gap-y-3">
        <a
          href={LIVE_DEMO.url}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 rounded-md border border-accent bg-accent px-5 py-2.5 text-sm font-medium text-bg shadow-sm transition hover:bg-accent-hover hover:border-accent-hover"
        >
          → 打开可交互 Demo（{LIVE_DEMO.url.replace(/^https?:\/\//, "")}）
        </a>
        <span class="font-mono text-xs text-text-tertiary">{LIVE_DEMO.warning} · 可在浏览器中直接输入意图、观察 Stretch RE3 自主执行</span>
      </div>
    </section>

    <!-- Storyboard -->
    <section class="mt-16">
      <h2 class="text-sm font-medium uppercase tracking-wider text-text-tertiary">端到端链路 · End-to-End Pipeline</h2>
      <div class="mt-6 grid gap-6 md:grid-cols-3">
        {STORYBOARD.map((frame) => (
          <StoryboardFrame
            step={frame.step}
            title={frame.title}
            caption={frame.caption}
            image={frame.image}
          />
        ))}
      </div>
      <p class="mt-6 font-mono text-xs leading-relaxed text-text-tertiary">
        signal → IntentToken JSON → py_trees → MuJoCo · 全链路事件落盘可回放
      </p>
    </section>

    <!-- Demo Stills -->
    <section id="demo" class="mt-16 scroll-mt-8">
      <h2 class="text-sm font-medium uppercase tracking-wider text-text-tertiary">DEMO 细节 · Demo Details</h2>
      <p class="mt-4 text-sm leading-relaxed text-text">
        Stretch RE3 在病房场景自主完成"取水送到床边"全流程。每次运行从 MJCF 实时查物体位姿、算分析 IK、步进物理——不是录好的动画。
      </p>

      <div class="mt-6 grid gap-4 md:grid-cols-3">
        {DEMO_STILLS.map((still, i) => (
          <figure class="flex flex-col gap-2">
            <div class="overflow-hidden rounded-md border border-border bg-bg-card">
              <img
                src={`${base}/${still.image}`}
                alt={still.caption}
                loading="lazy"
                class="block h-auto w-full"
              />
            </div>
            <figcaption class="flex items-baseline gap-2 text-xs text-text-muted">
              <span class="font-mono text-text-tertiary">{String(i + 1).padStart(2, "0")}</span>
              <span class="leading-relaxed">{still.caption}</span>
            </figcaption>
          </figure>
        ))}
      </div>
    </section>

    <!-- Contribution -->
    <section class="mt-16 rounded-md border border-border bg-bg-card px-6 py-6 md:px-8 md:py-8">
      <h2 class="text-sm font-medium uppercase tracking-wider text-text-tertiary">核心实现 · Core Implementation</h2>
      <p class="mt-4 text-sm leading-relaxed text-text">{CONTRIBUTION.intro}</p>
      <ul class="mt-4 space-y-2 text-sm leading-relaxed text-text">
        {CONTRIBUTION.did.map((item) => (
          <li class="flex gap-2">
            <span class="mt-[0.35rem] h-1.5 w-1.5 shrink-0 rounded-full bg-accent" />
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </section>

    <!-- Technical details (collapsible) -->
    <section id="details" class="mt-16 scroll-mt-8">
      <h2 class="text-sm font-medium uppercase tracking-wider text-text-tertiary">技术细节 · Technical Details</h2>
      <p class="mt-4 text-sm leading-relaxed text-text-muted">点击展开。</p>

      <div class="mt-6 divide-y divide-border border-y border-border">
        {TECH_DETAILS.map((item) => (
          <details class="group py-4">
            <summary class="flex cursor-pointer items-center justify-between gap-4 text-sm font-medium text-text hover:text-accent">
              <span>{item.summary}</span>
              <span class="font-mono text-xs text-text-tertiary transition-transform group-open:rotate-45">+</span>
            </summary>
            <ul class="mt-3 space-y-1.5 text-sm leading-relaxed text-text-muted">
              {item.body.map((line) => (
                <li>{line}</li>
              ))}
            </ul>
            {"image" in item && item.image && (
              <div class="mt-4 overflow-hidden rounded-md border border-border bg-bg-card">
                <img src={`${base}/${item.image}`} alt={item.summary} loading="lazy" class="block w-full" />
              </div>
            )}
          </details>
        ))}
      </div>
    </section>

    <!-- Contact -->
    <section class="mt-16">
      <h2 class="text-sm font-medium uppercase tracking-wider text-text-tertiary">联系 · Contact</h2>
      <div class="mt-4 flex flex-wrap items-center gap-x-6 gap-y-2 text-sm">
        <a href={`mailto:${SITE.email}`} class="text-accent hover:text-accent-hover">→ {SITE.email}</a>
        <a href={SITE.repo} target="_blank" rel="noopener" class="text-accent hover:text-accent-hover">→ 源码</a>
      </div>
    </section>

  </article>
</BaseLayout>
