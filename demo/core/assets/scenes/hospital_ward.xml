<mujoco model="hospital_ward_v3">
  <include file="stretch.xml"/>

  <statistic center="2.5 0 1.0" extent="6" meansize="0.1"/>

  <visual>
    <headlight diffuse="0.7 0.7 0.7" ambient="0.45 0.45 0.45" specular="0.1 0.1 0.1"/>
    <rgba haze="0.85 0.87 0.92 1"/>
    <global azimuth="90" elevation="-25" offwidth="1280" offheight="720"/>
  </visual>

  <asset>
    <!-- Simple materials kept for patient, cup, collision stand-ins -->
    <material name="cup_mat"       rgba="0.25 0.60 0.85 1"/>
    <material name="skin"          rgba="0.95 0.80 0.70 1"/>
    <material name="gown"          rgba="0.55 0.78 0.88 1"/>
    <texture type="skybox" builtin="gradient" rgb1="0.88 0.92 0.96" rgb2="1 1 1" width="512" height="3072"/>

    <!-- Madduck furniture meshes -->
    <mesh name="bed_m"      file="madduck/meshes/Bed.obj"       scale="0.65 0.65 0.65"/>
    <mesh name="cabinet_m"  file="madduck/meshes/Cabinet_3.obj" scale="1.0 1.0 1.0"/>
    <mesh name="chair_m"    file="madduck/meshes/Chair.obj"     scale="1.0 1.0 1.0"/>
    <mesh name="ivpole_m"   file="madduck/meshes/Iv_bag_holder.obj" scale="1.0 1.0 1.0"/>

    <!-- Madduck architectural meshes -->
    <mesh name="wall_m"         file="madduck/meshes/Tile_Wall.obj"          scale="1.0 1.0 1.0"/>
    <mesh name="wall_door_m"    file="madduck/meshes/Tile_Wall_Doorway_1.obj" scale="1.0 1.0 1.0"/>
    <mesh name="floor_m"        file="madduck/meshes/Floor_tile_1.obj"       scale="1.0 1.0 1.0"/>
    <mesh name="ceiling_m"      file="madduck/meshes/Ceiling_Tile.obj"       scale="1.0 1.0 1.0"/>
    <mesh name="ceil_light_m"   file="madduck/meshes/Ceiling_Light.obj"      scale="1.0 1.0 1.0"/>
    <mesh name="door_m"         file="madduck/meshes/Door_1.obj"             scale="1.0 1.0 1.0"/>

    <!-- Madduck textures & materials -->
    <texture name="bed_t"     type="2d" file="madduck/textures/bed.png"/>
    <texture name="cabinet_t" type="2d" file="madduck/textures/cabinet.png"/>
    <texture name="ivpole_t"  type="2d" file="madduck/textures/iv.png"/>
    <texture name="wall_t"    type="2d" file="madduck/textures/walls.png"/>
    <texture name="floor_t"   type="2d" file="madduck/textures/floor.png"/>
    <texture name="ceiling_t" type="2d" file="madduck/textures/ceiling.png"/>
    <texture name="ceillight_t" type="2d" file="madduck/textures/ceiling_light.png"/>
    <texture name="door_t"    type="2d" file="madduck/textures/door.png"/>

    <material name="bed_mat"       texture="bed_t"/>
    <material name="cabinet_mat"   texture="cabinet_t"/>
    <material name="chair_mat"     rgba="0.55 0.40 0.30 1"/>
    <material name="ivpole_mat"    texture="ivpole_t"/>
    <material name="wall_mat"      texture="wall_t"/>
    <material name="floor_mat"     texture="floor_t" reflectance="0.15"/>
    <!-- Ceiling material: slight transparency so top_down camera can see through. -->
    <material name="ceiling_mat"   texture="ceiling_t" rgba="1 1 1 0.55"/>
    <material name="ceillight_mat" texture="ceillight_t" emission="0.4"/>
    <material name="door_mat"      texture="door_t"/>
  </asset>

  <worldbody>
    <!-- Ambient lights (all five are toggled off together by TURN_OFF_LIGHT) -->
    <light name="room_amb_0" pos="1.5  0   2.4" dir="0 0 -1" directional="true" diffuse="0.45 0.45 0.45"/>
    <light name="room_amb_1" pos="3.5  0   2.4" dir="0 0 -1" directional="true" diffuse="0.45 0.45 0.45"/>
    <light name="room_amb_2" pos="2.5 -1.5 2.2" dir="0 0.4 -1" diffuse="0.25 0.25 0.30"/>

    <!-- ===================== FLOOR ===================== -->
    <!-- Floor_tile_1 is Z-up, 2x2m, bottom at z=0. Tile 3 x 2 to cover X[0..6] x Y[-2..+2]. Tiles under wall are hidden by walls at X=5. -->
    <body name="floor_group">
      <!-- Invisible collision plane underneath everything -->
      <geom name="floor_collision" type="plane" pos="2.25 0 0" size="3.25 2.5 0.05" rgba="0 0 0 0" contype="1" conaffinity="1"/>
      <!-- 4x2 tile grid: X centers at -0.5, 1.5, 3.5, 5.5 (covers X[-1.5..+6.5]), Y centers at -1, +1. -->
      <geom type="mesh" mesh="floor_m" material="floor_mat" pos="-0.5 -1 0" contype="0" conaffinity="0"/>
      <geom type="mesh" mesh="floor_m" material="floor_mat" pos="-0.5  1 0" contype="0" conaffinity="0"/>
      <geom type="mesh" mesh="floor_m" material="floor_mat" pos="1.5 -1 0" contype="0" conaffinity="0"/>
      <geom type="mesh" mesh="floor_m" material="floor_mat" pos="1.5  1 0" contype="0" conaffinity="0"/>
      <geom type="mesh" mesh="floor_m" material="floor_mat" pos="3.5 -1 0" contype="0" conaffinity="0"/>
      <geom type="mesh" mesh="floor_m" material="floor_mat" pos="3.5  1 0" contype="0" conaffinity="0"/>
      <geom type="mesh" mesh="floor_m" material="floor_mat" pos="5.5 -1 0" contype="0" conaffinity="0"/>
      <geom type="mesh" mesh="floor_m" material="floor_mat" pos="5.5  1 0" contype="0" conaffinity="0"/>
    </body>

    <!-- ===================== WALLS ===================== -->
    <!-- Tile_Wall is Y-up: euler="90 0 0" makes it stand with bottom at z=0, width 2m along X, thickness ~0.177 along Y.
         For walls running along Y (back, front), additionally rotate Z by 90 deg → euler="90 0 90". -->

    <body name="walls">
      <!-- NOTE: compiler angle="radian" is inherited from stretch.xml, so all euler values here are in RADIANS.
           90deg = 1.5708, 180deg = 3.1416, -90deg = -1.5708. -->

      <!-- Wall transforms derived from mesh orientation:
           Tile_Wall and Tile_Wall_Doorway_1 are Y-up meshes (width X=2m, height Y=2.5m, thickness Z~0.18m, bottom at mesh_y=0).
           Walls running along X (left/right walls): mesh X -> world X, mesh Y -> world Z. Euler="pi/2 0 0".
           Walls running along Y (front/back walls): mesh X -> world Y, mesh Y -> world Z. Euler="pi/2 pi/2 0". -->

      <!-- LEFT WALL (Y=+2, runs along X, 3 tiles centered at X=1,3,5) -->
      <geom type="mesh" mesh="wall_m" material="wall_mat" pos="1 2 0" euler="1.5708 0 0" contype="1" conaffinity="1"/>
      <geom type="mesh" mesh="wall_m" material="wall_mat" pos="3 2 0" euler="1.5708 0 0" contype="1" conaffinity="1"/>
      <geom type="mesh" mesh="wall_m" material="wall_mat" pos="5 2 0" euler="1.5708 0 0" contype="1" conaffinity="1"/>

      <!-- RIGHT WALL (Y=-2, runs along X, 3 tiles) -->
      <geom type="mesh" mesh="wall_m" material="wall_mat" pos="1 -2 0" euler="1.5708 0 0" contype="1" conaffinity="1"/>
      <geom type="mesh" mesh="wall_m" material="wall_mat" pos="3 -2 0" euler="1.5708 0 0" contype="1" conaffinity="1"/>
      <geom type="mesh" mesh="wall_m" material="wall_mat" pos="5 -2 0" euler="1.5708 0 0" contype="1" conaffinity="1"/>

      <!-- BACK WALL (X=+5, runs along Y, 2 tiles at Y=-1, +1) -->
      <geom type="mesh" mesh="wall_m" material="wall_mat" pos="5 -1 0" euler="1.5708 1.5708 0" contype="1" conaffinity="1"/>
      <geom type="mesh" mesh="wall_m" material="wall_mat" pos="5  1 0" euler="1.5708 1.5708 0" contype="1" conaffinity="1"/>

      <!-- FRONT WALL (X=-0.5, pushed back slightly so robot spawn at (0,0,0) is inside the room, not inside wall geom).
           Doorway tile at Y=+1, solid tile at Y=-1. -->
      <geom type="mesh" mesh="wall_m"      material="wall_mat" pos="-0.5 -1 0" euler="1.5708 1.5708 0" contype="1" conaffinity="1"/>
      <geom type="mesh" mesh="wall_door_m" material="wall_mat" pos="-0.5  1 0" euler="1.5708 1.5708 0" contype="1" conaffinity="1"/>

      <!-- DOOR: Y-up mesh (height 2m along mesh Y, width 1m along mesh X from 0..1, hinge at mesh X=0).
           Placed in the doorway (front-wall Y=+1 tile), slightly behind the wall so robot can still enter. -->
      <geom type="mesh" mesh="door_m" material="door_mat" pos="-0.45 0.1 0" euler="1.5708 1.5708 0" contype="0" conaffinity="0"/>
    </body>

    <!-- ===================== CEILING ===================== -->
    <!-- Ceiling_Tile Z-up, 2x2m, bottom at z=0. Mount at z=2.5 (room height). 3x2 grid. -->
    <body name="ceiling_group">
      <!-- 3x2 ceiling tile grid: X centers at 0.5, 2.5, 4.5 (covers X[-0.5..+5.5]), Y centers at -1, +1. -->
      <geom type="mesh" mesh="ceiling_m" material="ceiling_mat" pos="0.5 -1 2.5" contype="0" conaffinity="0"/>
      <geom type="mesh" mesh="ceiling_m" material="ceiling_mat" pos="0.5  1 2.5" contype="0" conaffinity="0"/>
      <geom type="mesh" mesh="ceiling_m" material="ceiling_mat" pos="2.5 -1 2.5" contype="0" conaffinity="0"/>
      <geom type="mesh" mesh="ceiling_m" material="ceiling_mat" pos="2.5  1 2.5" contype="0" conaffinity="0"/>
      <geom type="mesh" mesh="ceiling_m" material="ceiling_mat" pos="4.5 -1 2.5" contype="0" conaffinity="0"/>
      <geom type="mesh" mesh="ceiling_m" material="ceiling_mat" pos="4.5  1 2.5" contype="0" conaffinity="0"/>

      <!-- Two ceiling lights hanging just below ceiling (mesh hangs in -Z direction to -0.062). -->
      <geom name="ceil_light_geom_0" type="mesh" mesh="ceil_light_m" material="ceillight_mat" pos="1.2 0 2.5" contype="0" conaffinity="0"/>
      <geom name="ceil_light_geom_1" type="mesh" mesh="ceil_light_m" material="ceillight_mat" pos="3.5 0 2.5" contype="0" conaffinity="0"/>
    </body>

    <!-- Emissive point lights near ceiling lights -->
    <light name="ceil_pt_0" pos="1.5 0 2.4" dir="0 0 -1" diffuse="0.35 0.35 0.33" specular="0.1 0.1 0.1"/>
    <light name="ceil_pt_1" pos="3.5 0 2.4" dir="0 0 -1" diffuse="0.35 0.35 0.33" specular="0.1 0.1 0.1"/>

    <!-- ===================== FURNITURE (anchor bodies, unchanged positions) ===================== -->

    <body name="bed" pos="3.8 0 0.33">
      <geom type="mesh" mesh="bed_m" material="bed_mat" euler="0 0 90" contype="0" conaffinity="0"/>
      <geom name="bed_col" type="box" pos="0 0 0.22" size="0.95 0.48 0.08" rgba="0 0 0 0" contype="1" conaffinity="1"/>
    </body>

    <body name="patient" pos="3.8 0 0.61">
      <geom type="capsule" fromto="-0.3 0 0  0.3 0 0" size="0.15" material="gown"/>
      <geom type="sphere" pos="0.47 0 0.02" size="0.10" material="skin"/>
      <geom type="capsule" fromto="0.1  0.20 0.02  -0.2  0.25 0" size="0.05" material="gown"/>
      <geom type="capsule" fromto="0.1 -0.20 0.02  -0.2 -0.25 0" size="0.05" material="gown"/>
      <geom type="capsule" fromto="-0.3 0.10 0.02 -0.72 0.12 0" size="0.07" material="gown"/>
      <geom type="capsule" fromto="-0.3 -0.10 0.02 -0.72 -0.12 0" size="0.07" material="gown"/>
    </body>

    <body name="nightstand" pos="3.8 0.65 0.506">
      <geom type="mesh" mesh="cabinet_m" material="cabinet_mat" contype="0" conaffinity="0"/>
      <geom name="cab_col" type="box" pos="0 0 0.28" size="0.28 0.14 0.01" rgba="0 0 0 0" contype="1" conaffinity="1"/>
    </body>

    <body name="cup" pos="3.80 0.65 0.85">
      <freejoint/>
      <geom name="cup_body" type="cylinder" size="0.04 0.055" mass="0.18" material="cup_mat"
            friction="1.2 0.005 0.0001"/>
    </body>

    <body name="visitor_chair" pos="1.0 1.5 0.817">
      <geom type="mesh" mesh="chair_m" material="chair_mat" euler="0 0 -90" contype="0" conaffinity="0"/>
      <geom type="box" pos="0 0 -0.4" size="0.4 0.45 0.4" rgba="0 0 0 0" contype="1" conaffinity="1"/>
    </body>

    <!-- Wall-mounted TV on the LEFT wall (Y=+2) facing -Y into the room.
         Placed between bed and visitor_chair so demo_view / top_down /
         bedside_view all see it.  tv_screen rgba is toggled at runtime by
         ADJUST_TV (dark when off, bright sky-blue when on). -->
    <body name="tv" pos="3.0 1.95 1.5">
      <geom name="tv_frame" type="box" size="0.55 0.04 0.34" material="chair_mat" contype="0" conaffinity="0"/>
      <geom name="tv_screen" type="box" pos="0 -0.045 0" size="0.50 0.005 0.30" rgba="0.05 0.05 0.08 1" contype="0" conaffinity="0"/>
    </body>

    <!-- Nurse: mocap body animated by CALL_HELP. Hidden underground when idle
         (mocap_pos.z = -10). The skill teleports her to door entry, slides her
         to bedside to "show face", pauses, then slides her back out. Geoms
         are layered so +X side has eyes/mouth — keeps her face presented when
         she stops in the room facing forward (+X). -->
    <body name="nurse" mocap="true" pos="-3 1 -10">
      <geom type="capsule" fromto="0 0 0.10 0 0 0.90" size="0.10" rgba="0.95 0.95 1.0 1" contype="0" conaffinity="0"/>
      <geom type="capsule" fromto="0 0 0.90 0 0 1.45" size="0.22" rgba="0.15 0.45 0.85 1" contype="0" conaffinity="0"/>
      <geom type="sphere" pos="0 0 1.62" size="0.13" rgba="0.95 0.80 0.70 1" contype="0" conaffinity="0"/>
      <!-- Hair cap (back of head dark) -->
      <geom type="sphere" pos="-0.03 0 1.69" size="0.115" rgba="0.30 0.20 0.15 1" contype="0" conaffinity="0"/>
      <!-- Face (eyes + mouth on +X side) -->
      <geom type="sphere" pos="0.115 -0.045 1.65" size="0.014" rgba="0.05 0.05 0.05 1" contype="0" conaffinity="0"/>
      <geom type="sphere" pos="0.115  0.045 1.65" size="0.014" rgba="0.05 0.05 0.05 1" contype="0" conaffinity="0"/>
      <geom type="box"    pos="0.122  0.000 1.55" size="0.022 0.005 0.005" rgba="0.55 0.20 0.20 1" contype="0" conaffinity="0"/>
      <!-- Nurse cap (small white box on top of head) -->
      <geom type="box" pos="0 0 1.78" size="0.10 0.10 0.025" rgba="1 1 1 1" contype="0" conaffinity="0"/>
    </body>

    <body name="iv_pole" pos="2.8 -0.9 1.152">
      <freejoint/>
      <inertial pos="0 0 0.6" mass="4.0" diaginertia="2.5 2.5 0.02"/>
      <geom type="mesh" mesh="ivpole_m" material="ivpole_mat" euler="1.5708 0 0" contype="0" conaffinity="0"/>
      <geom type="capsule" fromto="0 0 -1.14 0 0 0.82" size="0.025" rgba="0 0 0 0" contype="1" conaffinity="1"/>
      <geom type="cylinder" pos="0 0 -1.13" size="0.22 0.02" rgba="0 0 0 0" contype="1" conaffinity="1"/>
    </body>

    <!-- Cameras (fovy intrinsics preserved). demo_view positioned in front-right corner so robot (at ~origin) and bed are both in frame. -->
    <!-- demo_view camera: from back-right corner looking diagonally forward-left across the room.
         Captures bed+patient (near), chair+iv pole (mid), robot at doorway (far). -->
    <camera name="demo_view" mode="targetbody" target="visitor_chair" pos="4.9 -1.85 2.2" fovy="85"/>
    <camera name="top_down" pos="2.25 0 5.5" xyaxes="1 0 0  0 1 0" fovy="70"/>
    <camera name="grasp_view" mode="targetbody" target="cup" pos="3.5 1.9 1.5" fovy="55"/>
    <camera name="bedside_view" mode="targetbody" target="patient" pos="2.6 -1.0 1.4" fovy="65"/>
    <camera name="tv_view" mode="targetbody" target="tv" pos="3.0 0.3 1.3" fovy="55"/>
  </worldbody>

</mujoco>
