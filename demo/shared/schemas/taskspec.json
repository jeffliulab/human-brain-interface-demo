        "alternatives": {
          "items": {
            "$ref": "#/$defs/Alternative"
          },
          "title": "Alternatives",
          "type": "array"
        },
        "drift_score": {
          "default": 0.05,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Drift Score",
          "type": "number"
        },
        "timestamp": {
          "format": "date-time",
          "title": "Timestamp",
          "type": "string"
        },
        "source_text": {
          "default": "",
          "title": "Source Text",
          "type": "string"
        }
      },
      "required": [
        "token",
        "confidence"
      ],
      "title": "IntentToken",
      "type": "object"
    },
    "Subtask": {
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "type": {
          "enum": [
            "locate",
            "grasp",
            "lift",
            "deliver",
            "navigate",
